# ─── Runtime ─────────────────────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO
# When true, every external system (Gemini, Vertex, Figma, Jira, Gmail, Drive)
# falls back to a deterministic mock. The whole platform boots with zero creds.
MOCK_MODE=true

# Per-service overrides. Blank = inherit MOCK_MODE. Set one to false to take a single
# integration live while the rest stay mocked — e.g. real Figma frames without paying
# for a single Gemini token.
#   LLM_MOCK=
#   FIGMA_MOCK=false
#   GMAIL_MOCK=
#   DRIVE_MOCK=
#   JIRA_MOCK=

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=sdlc
POSTGRES_PASSWORD=sdlc
POSTGRES_DB=sdlc
DATABASE_URL=postgresql+psycopg://sdlc:sdlc@postgres:5432/sdlc

# ─── Google Gemini 2.5 (AI Studio) ───────────────────────────────────────────
# Set GOOGLE_API_KEY and MOCK_MODE=false and all five thinking agents (1,2,3,4,6) go live.
# Agent 5 never calls a model — it is the approval gate, and that is on purpose.
# Verify with: GET /api/integrations/llm/selftest
GOOGLE_API_KEY=

# gemini-2.5-pro has NO free-tier quota on many projects (the API returns "limit: 0", which means
# "you never had any", not "you ran out"). If you are not billing-enabled, use flash:
#   GEMINI_MODEL=gemini-2.5-flash
# Model names churn HARD. 2.5 was retired for new keys; gemini-3-pro now redirects to a 3.1 preview.
# Do not trust this default — ask your key what it can actually call:
#     GET /api/integrations/llm/models
GEMINI_MODEL=gemini-3.1-pro
GEMINI_FLASH_MODEL=gemini-3.1-flash

# text-embedding-004 is gone from the current API version — embedContent returns 404.
GEMINI_EMBED_MODEL=gemini-embedding-001

# Agent 4's SRS is the largest single generation. Too small a budget truncates it into
# unparseable JSON — which the client now detects and reports rather than silently committing.
MAX_OUTPUT_TOKENS=32768

# ─── Vertex AI (enterprise path: VPC-SC, CMEK, data residency asia-south1) ───
USE_VERTEX=false
VERTEX_PROJECT=hdfc-sdlc-prod
VERTEX_LOCATION=asia-south1

# ─── Wireframes: Google Stitch (default) or Figma ────────────────────────────
# stitch | figma | mock
#
# Stitch generates a screen FROM TEXT — which is what Agent 3 already produces — and returns HTML
# plus a screenshot, so a wireframe can be embedded in the BRD itself rather than hidden behind a
# link only seat-holders can open. It is free in Google Labs (with monthly generation caps).
#
# Figma's write-to-canvas wants geometry and needs a FULL SEAT ON A PAID PLAN. Use it only if the
# frames must live in a Figma file your designers already work in.
#
# Verify either with: GET /api/integrations/wireframes/tools
WIREFRAME_PROVIDER=stitch
# The MCP server is on googleapis.com. (stitch.withgoogle.com is the web app, not the API.)
STITCH_MCP_URL=https://stitch.googleapis.com/mcp
STITCH_API_KEY=
# Blank inherits MOCK_MODE. Set to false to take Stitch live while everything else stays mocked.
STITCH_MOCK=

# ─── Figma (via MCP) ─────────────────────────────────────────────────────────
# Remote server — the only option for a cloud-hosted backend. The local server
# (127.0.0.1:3845) needs the Figma desktop app on the SAME machine, so it is useless
# from Render/Cloud Run.
# Write-to-canvas (create frames) requires a FULL SEAT on a paid plan. Dev seats are
# read-only outside drafts; Starter/View seats get ~6 tool calls a month.
FIGMA_MCP_URL=https://mcp.figma.com/mcp
FIGMA_TOKEN=
FIGMA_TEAM_ID=

# ─── Google Workspace ────────────────────────────────────────────────────────
GOOGLE_SA_JSON=            # path to service-account json (domain-wide delegation)
GMAIL_SENDER=sdlc-bot@hdfcbank.com
GDRIVE_ROOT_FOLDER_ID=

# ─── Jira ────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://hdfcbank.atlassian.net
JIRA_EMAIL=
JIRA_TOKEN=
JIRA_PROJECT_KEY=HDFC

# ─── Security ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-prod
APPROVAL_TOKEN_TTL_HOURS=72
