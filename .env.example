# ─── Runtime ─────────────────────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO
# When true, every external system (Gemini, Vertex, Figma, Jira, Gmail, Drive)
# falls back to a deterministic mock. The whole platform boots with zero creds.
MOCK_MODE=true

# Per-service overrides. Blank = inherit MOCK_MODE. Set one to false to take a single
# integration live while the rest stay mocked — e.g. real Figma frames without paying
# for a single Gemini token.
#   LLM_MOCK=
#   FIGMA_MOCK=false
#   GMAIL_MOCK=
#   DRIVE_MOCK=
#   JIRA_MOCK=

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=sdlc
POSTGRES_PASSWORD=sdlc
POSTGRES_DB=sdlc
DATABASE_URL=postgresql+psycopg://sdlc:sdlc@postgres:5432/sdlc

# ─── Google Gemini 2.5 (AI Studio) ───────────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004

# ─── Vertex AI (enterprise path: VPC-SC, CMEK, data residency asia-south1) ───
USE_VERTEX=false
VERTEX_PROJECT=hdfc-sdlc-prod
VERTEX_LOCATION=asia-south1

# ─── Figma (via MCP) ─────────────────────────────────────────────────────────
# Remote server — the only option for a cloud-hosted backend. The local server
# (127.0.0.1:3845) needs the Figma desktop app on the SAME machine, so it is useless
# from Render/Cloud Run.
# Write-to-canvas (create frames) requires a FULL SEAT on a paid plan. Dev seats are
# read-only outside drafts; Starter/View seats get ~6 tool calls a month.
FIGMA_MCP_URL=https://mcp.figma.com/mcp
FIGMA_TOKEN=
FIGMA_TEAM_ID=

# ─── Google Workspace ────────────────────────────────────────────────────────
GOOGLE_SA_JSON=            # path to service-account json (domain-wide delegation)
GMAIL_SENDER=sdlc-bot@hdfcbank.com
GDRIVE_ROOT_FOLDER_ID=

# ─── Jira ────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://hdfcbank.atlassian.net
JIRA_EMAIL=
JIRA_TOKEN=
JIRA_PROJECT_KEY=HDFC

# ─── Security ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-prod
APPROVAL_TOKEN_TTL_HOURS=72
